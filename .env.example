NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/luxe-salon
CLIENT_URL=http://localhost:5173

# SMTP email provider. For Gmail, use a Gmail App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM="Luxe Salon <your-email@gmail.com>"
SALON_EMAIL=bookings@example.com

# Free fallback if Gmail SMTP is blocked by hosting.
# First submission requires email confirmation from FormSubmit.
FORMSUBMIT_EMAIL=bookings@example.com

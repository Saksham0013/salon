NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/luxe-salon
CLIENT_URL=http://localhost:5173

# Free Gmail sender through Google Apps Script. If set, this is used before Brevo.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec
GOOGLE_SCRIPT_SECRET=replace-this-with-your-secret
GOOGLE_SCRIPT_SENDER_NAME=Luxe Salon

# Brevo transactional email. BREVO_SENDER_EMAIL must be a verified sender in Brevo.
BREVO_API_KEY=xkeysib-your-brevo-api-key
BREVO_SENDER_EMAIL=verified-sender@example.com
BREVO_SENDER_NAME=Luxe Salon
SALON_EMAIL=bookings@example.com
